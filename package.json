{
  "name": "xlab-token",
  "version": "1.0.4",
  "description": "Local-first token API usage and cost tracker for AI coding agents on one machine",
  "type": "module",
  "bin": {
    "xlab-token": "dist/cli.js"
  },
  "main": "./electron/main.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "prepublishOnly": "npm run build && npm test",
    "postinstall": "node scripts/postinstall.mjs",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "serve": "tsx src/cli.ts serve",
    "serve:watch": "tsx watch --watch-path=./src --watch-preserve-output --clear-screen=false src/cli.ts serve",
    "stats": "tsx src/cli.ts stats",
    "cost": "tsx src/cli.ts cost",
    "doctors": "tsx src/cli.ts doctors",
    "setup": "node dist/cli.js setup",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:check": "npm pack --dry-run",
    "pkg:build": "npm run build && pkg . --targets node18-win-x64 --output build/xlab-token.exe",
    "nexe:build": "npm run build && nexe dist/cli.js -o build/xlab-token.exe --build",
    "bundle": "node scripts/bundle.mjs",
    "exe:build": "npm run bundle && pkg dist/bundle.cjs --targets node18-win-x64 --output build/xlab-token.exe --public",
    "electron:dev": "electron .",
    "electron:build": "npm run build && npm run build-icons && electron-builder",
    "electron:build:win": "npm run build && npm run build-icons && electron-builder --win",
    "electron:build:mac": "npm run build && npm run build-icons && electron-builder --mac",
    "electron:build:linux": "npm run build && npm run build-icons && electron-builder --linux",
    "generate-icons": "node scripts/generate-icons.mjs",
    "build-icons": "node scripts/build-icons.mjs",
    "convert-icon": "node scripts/convert-icon.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "keywords": [
    "token-usage",
    "cost-tracking",
    "ai-agents",
    "claude-code",
    "cursor",
    "codex",
    "windsurf",
    "grok",
    "devin",
    "localhost",
    "xlab",
    "macos",
    "linux",
    "windows"
  ],
  "author": "XLab",
  "license": "MIT",
  "homepage": "https://github.com/quangminh1212/XLab_Token#readme",
  "bugs": {
    "url": "https://github.com/quangminh1212/XLab_Token/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quangminh1212/XLab_Token.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "pkg": {
    "assets": [
      "dist/**/*",
      "src/server/assets/**/*"
    ],
    "scripts": [
      "scripts/postinstall.mjs"
    ],
    "outputPath": "build"
  },
  "build": {
    "appId": "com.xlab.token",
    "productName": "XLab Token",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "electron/assets/icon.png",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.png",
      "category": "Development",
      "maintainer": "XLab",
      "vendor": "XLab"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/assets/icon.ico",
      "uninstallerIcon": "electron/assets/icon.ico",
      "installerHeaderIcon": "electron/assets/icon.ico"
    }
  },
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "README.md",
    "LICENSE",
    "docs",
    "run.sh",
    "run.bat"
  ],
  "devDependencies": {
    "@types/node": "^22.15.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "nexe": "^5.0.0-beta.4",
    "pkg": "^5.8.1",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
