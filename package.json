{
  "name": "xlab-token",
  "version": "1.0.2",
  "description": "Local-first token API usage and cost tracker for AI coding agents on one machine",
  "type": "module",
  "bin": {
    "xlab-token": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "prepublishOnly": "npm run build && npm test",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "serve": "tsx src/cli.ts serve",
    "serve:watch": "tsx watch --watch-path=./src --watch-preserve-output --clear-screen=false src/cli.ts serve",
    "stats": "tsx src/cli.ts stats",
    "cost": "tsx src/cli.ts cost",
    "doctors": "tsx src/cli.ts doctors",
    "test": "tsx --test src/**/*.test.ts src/**/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:check": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "keywords": [
    "token-usage",
    "cost-tracking",
    "ai-agents",
    "claude-code",
    "cursor",
    "codex",
    "windsurf",
    "grok",
    "devin",
    "localhost",
    "xlab",
    "macos",
    "linux",
    "windows"
  ],
  "author": "XLab",
  "license": "MIT",
  "homepage": "https://github.com/quangminh1212/XLab_Token#readme",
  "bugs": {
    "url": "https://github.com/quangminh1212/XLab_Token/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quangminh1212/XLab_Token.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "ATTRIBUTION.md",
    "run.sh",
    "run.bat"
  ],
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
