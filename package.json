{
  "name": "tokensage",
  "version": "2.0.0",
  "description": "Windows app for tracking AI token usage and costs",
  "main": "dist/proxy.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/proxy.js",
    "dev": "tsx src/proxy.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "clean": "rimraf dist coverage",
    "update-models": "tsx src/crawler.ts"
  },
  "keywords": [
    "token",
    "usage",
    "tracking",
    "cost",
    "ai",
    "llm",
    "windows"
  ],
  "author": "quangminh1212",
  "license": "MIT",
  "dependencies": {
    "tiktoken": "^1.0.17"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
